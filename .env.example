# Firebase Cloud Functions API Configuration
# Copy this file to .env and update with your values

# Base URL untuk Cloud Functions Project A
# Ganti dengan URL Cloud Functions yang sudah deploy
# Format: https://REGION-PROJECT-ID.cloudfunctions.net
# Contoh: https://us-central1-my-api-project.cloudfunctions.net
VITE_API_BASE_URL=https://us-central1-YOUR-PROJECT-A-ID.cloudfunctions.net
