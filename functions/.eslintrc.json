{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "google"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "require-jsdoc": 0,
    "max-len": ["error", { "code": 100 }],
    "new-cap": ["error", { "capIsNewExceptions": ["functions"] }]
  }
}
